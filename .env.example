# Anthropic
ANTHROPIC_API_KEY=your-api-key

# Server
PORT=3000

# Data
DATA_DIR=./data

# Agent
AGENT_MODEL=claude-sonnet-4-6

# Logging
LOG_LEVEL=info

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# MiniMax MCP Server (web_search tool)
# 需要 Coding Plan token（非普通 API Key），申请: https://www.minimax.io/
# 需要安装 uv: curl -LsSL https://astral.sh/uv/install.sh | sh
# MINIMAX_API_KEY=your_minimax_coding_plan_token
# MINIMAX_API_HOST=https://api.minimax.io
